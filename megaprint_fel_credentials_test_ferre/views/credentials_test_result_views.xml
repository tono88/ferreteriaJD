<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_megaprint_fel_credentials_test_result_form" model="ir.ui.view">
        <field name="name">megaprint.fel.credentials.test.result.form</field>
        <field name="model">megaprint.fel.credentials.test.result</field>
        <field name="arch" type="xml">
            <form string="Resultado de prueba de credenciales FEL" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="Resultado">
                            <field name="status" widget="badge"/>
                            <field name="journal_id"/>
                            <field name="tested_at"/>
                            <field name="environment"/>
                            <field name="endpoint"/>
                        </group>
                        <group string="Respuesta segura">
                            <field name="http_status"/>
                            <field name="functional_code"/>
                            <field name="token_received"/>
                            <field name="token_length" invisible="not token_received"/>
                            <field name="token_expiration" invisible="not token_received"/>
                            <field name="duration_ms"/>
                        </group>
                    </group>
                    <group string="Diagnóstico de credenciales">
                        <group>
                            <field name="masked_user"/>
                            <field name="user_length_raw"/>
                            <field name="user_length_clean"/>
                            <field name="user_has_edge_spaces"/>
                            <field name="user_sha256_partial"/>
                        </group>
                        <group>
                            <field name="api_key_length_raw"/>
                            <field name="api_key_length_clean"/>
                            <field name="api_key_has_edge_spaces"/>
                            <field name="api_key_sha256_partial"/>
                        </group>
                    </group>
                    <group string="Descripción funcional">
                        <field name="functional_description" nolabel="1"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Esta prueba no muestra ni guarda el valor completo de la API key o del token.
                        Tampoco crea facturas, asientos, movimientos de inventario ni órdenes POS.
                    </div>
                </sheet>
                <footer>
                    <button string="Cerrar" special="cancel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
