<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="report_invoice_brand_exact_inherit"
            name="Invoice: Dynamic Commercial Name"
            inherit_id="l10n_gt_fel_megaprint_report_ferre.report_fel_invoice">
    <xpath expr="//div[contains(concat(' ', normalize-space(@class), ' '), ' fel-commercial-name ')]" position="replace">
      <div class="fel-commercial-name" style="text-transform:uppercase;">
        <span t-esc="(o.journal_id and o.journal_id.direccion and o.journal_id.direccion.name) or o.company_id.name or ''"/>
      </div>
    </xpath>
  </template>
</odoo>
