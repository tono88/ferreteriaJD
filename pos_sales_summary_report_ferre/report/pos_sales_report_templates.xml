<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_pos_sales_summary">
        <main class="o_report_layout">
            <div class="page">
                <div class="row">
                    <div class="col-8">
                        <h3>REPORTE DE VENTAS</h3>
                        <div>DEL: <t t-esc="data.get('date_from') or ''"/> AL: <t t-esc="data.get('date_to') or ''"/></div>
                        <div>Punto de venta: <t t-esc="data.get('pos_config_name') or 'Todos'"/></div>
                        <div>Clientes: <t t-esc="data.get('partner_names') or 'Todos'"/></div>
                        <div>Zona horaria POS: <t t-esc="report_timezone"/></div>
                    </div>
                    <div class="col-4" style="text-align:right;">
                        <strong t-esc="company.name"/>
                        <br/><span t-esc="user_label"/>
                        <br/><span t-esc="now_label"/>
                    </div>
                </div>

                <div style="border:1px solid #999; padding:6px; margin-top:8px;">
                    <strong>De la factura</strong>
                    [<t t-esc="first_invoice"/>] a la factura [<t t-esc="last_invoice"/>]
                </div>

                <table class="table table-sm mt16" style="width:100%; font-size:9px;">
                    <thead>
                        <tr>
                            <th style="width:18%;">Fecha documento</th>
                            <th style="width:20%;">Cliente</th>
                            <th style="width:12%;">No. interno</th>
                            <th style="width:16%;">Factura / FEL</th>
                            <th style="width:10%; text-align:right;">Contado</th>
                            <th style="width:10%; text-align:right;">Otros</th>
                            <th style="width:10%; text-align:right;">Total</th>
                            <th style="width:14%;">Observación</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="not order_by_internal_correlative">
                            <t t-foreach="grouped" t-as="grp">
                                <tr><td colspan="8"><strong t-esc="grp['partner']"/></td></tr>
                                <t t-foreach="grp['lines']" t-as="line">
                                    <tr>
                                        <td t-esc="line['document_date_label']"/>
                                        <td t-esc="line['partner']"/>
                                        <td t-esc="line['correlative']"/>
                                        <td style="overflow-wrap:anywhere;" t-esc="line['invoice']"/>
                                        <td style="text-align:right;" t-esc="line['contado_fmt']"/>
                                        <td style="text-align:right;" t-esc="line['credito_fmt']"/>
                                        <td style="text-align:right;" t-esc="line['total_fmt']"/>
                                        <td t-esc="line['observation']"/>
                                    </tr>
                                </t>
                            </t>
                        </t>
                        <t t-else="">
                            <t t-foreach="lines_linear" t-as="line">
                                <tr>
                                    <td t-esc="line['document_date_label']"/>
                                    <td t-esc="line['partner']"/>
                                    <td t-esc="line['correlative']"/>
                                    <td style="overflow-wrap:anywhere;" t-esc="line['invoice']"/>
                                    <td style="text-align:right;" t-esc="line['contado_fmt']"/>
                                    <td style="text-align:right;" t-esc="line['credito_fmt']"/>
                                    <td style="text-align:right;" t-esc="line['total_fmt']"/>
                                    <td t-esc="line['observation']"/>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Total General</td>
                            <td style="text-align:right;"><strong t-esc="total_contado_fmt"/></td>
                            <td style="text-align:right;"><strong t-esc="total_credito_fmt"/></td>
                            <td style="text-align:right;"><strong t-esc="total_general_fmt"/></td>
                            <td/>
                        </tr>
                    </tfoot>
                </table>

                <div class="mt16 text-muted">
                    <small>Fecha documento: fecha fiscal de la factura publicada; para comprobantes o documentos inconsistentes se usa la fecha local de la orden POS.</small>
                </div>
            </div>
        </main>
    </template>
</odoo>
