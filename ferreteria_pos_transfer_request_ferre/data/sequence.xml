<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="sequence_transfer_request" model="ir.sequence">
        <field name="name">Solicitud entre sucursales</field>
        <field name="code">ferreteria.transfer.request</field>
        <field name="prefix">STS/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_transfer_incident" model="ir.sequence">
        <field name="name">Incidencia entre sucursales</field>
        <field name="code">ferreteria.transfer.incident</field>
        <field name="prefix">INC/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
