<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_transfer_request" model="ir.ui.view">
        <field name="name">stock.picking.form.transfer.request</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="(//field[@name='origin'])[1]" position="after">
                <field name="ferreteria_transfer_request_id"
                       readonly="1"
                       invisible="not ferreteria_transfer_request_id"/>
                <field name="ferreteria_transfer_stage"
                       readonly="1"
                       invisible="not ferreteria_transfer_request_id"/>
            </xpath>
        </field>
    </record>
</odoo>
