<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vlf_dashboard_update_presets_wizard_form" model="ir.ui.view">
        <field name="name">vlf.dashboard.update.presets.wizard.form</field>
        <field name="model">vlf.dashboard.update.presets.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar dashboards predeterminados">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Esta acción crea los indicadores faltantes y actualiza únicamente los elementos administrados por Dashboard Reports. No elimina elementos personalizados.
                    </div>
                </sheet>
                <footer>
                    <button name="action_update_presets" type="object" string="Actualizar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vlf_dashboard_update_presets_wizard" model="ir.actions.act_window">
        <field name="name">Actualizar dashboards predeterminados</field>
        <field name="res_model">vlf.dashboard.update.presets.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
