<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vlf_dashboard_todo_list" model="ir.ui.view">
        <field name="name">vlf.dashboard.todo.list</field>
        <field name="model">vlf.dashboard.todo</field>
        <field name="arch" type="xml">
            <list string="To-do Dashboard" editable="bottom">
                <field name="name"/>
                <field name="dashboard_id"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="deadline"/>
                <field name="user_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_vlf_dashboard_todo_form" model="ir.ui.view">
        <field name="name">vlf.dashboard.todo.form</field>
        <field name="model">vlf.dashboard.todo</field>
        <field name="arch" type="xml">
            <form string="To-do Dashboard">
                <header>
                    <button name="action_done" type="object" string="Marcar hecho" class="btn-primary" invisible="state == 'done'"/>
                    <button name="action_open" type="object" string="Reabrir" invisible="state != 'done'"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dashboard_id"/>
                        <field name="item_id"/>
                        <field name="state"/>
                        <field name="priority"/>
                        <field name="deadline"/>
                        <field name="user_id"/>
                        <field name="company_id"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vlf_dashboard_todo" model="ir.actions.act_window">
        <field name="name">To-do Dashboard</field>
        <field name="res_model">vlf.dashboard.todo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
