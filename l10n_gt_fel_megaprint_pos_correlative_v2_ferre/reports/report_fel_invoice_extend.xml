<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_fel_invoice_extend"
              inherit_id="l10n_gt_fel_megaprint_report_ferre.report_fel_invoice">
        <xpath expr="//div[@class='fw-bold' and normalize-space()='NÚMERO DTE:']/ancestor::table[1]//tr[last()]"
               position="after">
            <tr>
                <td style="width:27.5%;"><div class="fw-bold">No. interno:</div></td>
                <td colspan="3">
                    <span t-esc="o.internal_correlative or 'No asignado'"/>
                </td>
            </tr>
        </xpath>
    </template>
</odoo>
