<?xml version="1.0" encoding="UTF-8"?>
<templates id="custom_pos_receipt_templates" xml:space="preserve">
    <t t-name="custom_pos_receipt_ferre.ReceiptHeader"
       t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">
        <xpath expr="//div[@t-if='props.data.cashier']" position="after">
            <div t-if="props.data.partner">
                Cliente: <t t-esc="props.data.partner.name"/>
            </div>
        </xpath>
    </t>
</templates>
